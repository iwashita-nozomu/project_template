{
  "version": 13,
  "team": {
    "id": "repo_permanent_team",
    "report_root": "reports/agents",
    "branch_prefix": "agent",
    "worktree_scope_required": true,
    "default_runtime_policy": "design_first_single_writer_team",
    "task_catalog": "agents/task_catalog.yaml",
    "communication_protocol": "agents/COMMUNICATION_PROTOCOL.md",
    "canonical_runtime": "scripts/agent_tools/agent_team.py",
    "summary": "The manager is the single front-door role for intake, context sweep, library sweep, routing declaration, specialist activation, and escalation. Repo-changing tasks use an explicit staged flow of requirements organization -> research -> execution planning -> plan review -> detailed design -> detailed design review -> document flow review -> adversarial test design -> implementation. Research and scientific-software tasks default to independent research, experiment, report, reproducibility, scientific-computing, benchmark, artifact, and FAIR-style review roles. Repo-wide and workflow-heavy changes add independent project, docs-workflow, test-design, and Python review roles. Academic writing adds separate notation-definition review and logic-gap review before closeout. Plan review, detailed design review, document flow review, test design, notation-definition review, logic-gap review, project review, docs-workflow review, Python review, and report review are all separate agents, every reviewed execution role must apply feedback before the next handoff, and detailed design review remains the strongest pre-implementation gate. Only implementer may modify repository source files."
  },
  "always_on_roles": [
    {
      "id": "manager",
      "owns": [
        "user_intent_capture",
        "acceptance_criteria",
        "ambiguity_tracking",
        "context_sweep",
        "library_sweep",
        "planning",
        "routing_declaration",
        "scope_locking",
        "specialist_activation",
        "permission_decisions",
        "delegation",
        "escalation",
        "cross_role_handoffs"
      ],
      "required_outputs": [
        "intent_brief.md",
        "team_manifest.yaml",
        "decision_log.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "intent_brief",
          "decision_log",
          "team_manifest"
        ],
        "notes": "The manager records intake, context sweep, library sweep, routing declarations, and decisions only in the run artifact bundle."
      }
    },
    {
      "id": "manager_reviewer",
      "owns": [
        "scope_review",
        "acceptance_review",
        "routing_review"
      ],
      "required_outputs": [
        "management_review.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "management_review"
        ],
        "notes": "The manager reviewer approves or challenges scope, acceptance criteria, and specialist activation."
      }
    },
    {
      "id": "designer",
      "owns": [
        "solution_design",
        "module_boundary_design",
        "change_plan",
        "detailed_design_documentation",
        "existing_code_reuse_plan",
        "style_continuity_plan"
      ],
      "required_outputs": [
        "design_brief.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "design_brief"
        ],
        "notes": "The designer produces the detailed design document before coding begins, including reuse-first choices and the existing writing/style conventions to follow."
      }
    },
    {
      "id": "design_reviewer",
      "owns": [
        "design_review",
        "risk_review",
        "simplicity_review",
        "implementation_readiness_review",
        "reuse_conformity_review"
      ],
      "required_outputs": [
        "design_review.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "design_review"
        ],
        "notes": "The design reviewer independently checks the detailed design document, implementation readiness, and whether existing code, naming, and writing style are being followed. This is the most important pre-implementation review gate."
      }
    },
    {
      "id": "document_flow_reviewer",
      "owns": [
        "top_down_readability_review",
        "section_order_review",
        "term_introduction_review",
        "reader_path_review",
        "document_coherence_review"
      ],
      "required_outputs": [
        "document_flow_review.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "document_flow_review"
        ],
        "notes": "The document-flow reviewer reads the document linearly from the top and checks whether a first reader can follow the meaning without backtracking. It stays separate from the design reviewer."
      }
    },
    {
      "id": "test_designer",
      "activation": "static_test_design_needed",
      "owns": [
        "static_path_survey",
        "boundary_case_design",
        "adversarial_case_design",
        "failure_mode_inventory",
        "regression_test_plan"
      ],
      "required_outputs": [
        "test_plan.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "test_plan"
        ],
        "notes": "The test designer statically analyzes the approved design and existing code paths, then records the nastiest edge cases, failure modes, and regression-focused test plan before implementation expands."
      }
    },
    {
      "id": "implementer",
      "owns": [
        "code_and_docs_edits",
        "local_validation",
        "reuse_first_implementation"
      ],
      "required_outputs": [
        "decision_log.md"
      ],
      "write_policy": {
        "mode": "worktree_scope_plus_artifacts",
        "allowed_artifacts": [
          "decision_log"
        ],
        "requires_worktree_scope": true,
        "notes": "The implementer is the only role allowed to modify repository files, and only inside WORKTREE_SCOPE.md editable directories. It must prefer extending existing code and mirroring existing style over introducing new patterns."
      }
    },
    {
      "id": "change_reviewer",
      "owns": [
        "implementation_review",
        "regression_review",
        "design_guardrails"
      ],
      "required_outputs": [
        "change_review.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "change_review"
        ],
        "notes": "The implementation reviewer checks each coding chunk and may only update review artifacts."
      }
    },
    {
      "id": "final_reviewer",
      "owns": [
        "final_independent_review",
        "ship_blockers",
        "risk_summary"
      ],
      "required_outputs": [
        "final_review.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "final_review"
        ],
        "notes": "The final reviewer performs an independent ship decision and remains artifact-only."
      }
    },
    {
      "id": "verifier",
      "owns": [
        "ci_execution",
        "quality_gates"
      ],
      "required_outputs": [
        "verification.txt"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "verification"
        ],
        "notes": "Verification may update only the verification artifact."
      }
    },
    {
      "id": "auditor",
      "owns": [
        "evidence_capture",
        "closeout",
        "retrospective"
      ],
      "required_outputs": [
        "retrospective.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "retrospective"
        ],
        "notes": "Audit closeout is recorded only in retrospective artifacts."
      }
    }
  ],
  "specialist_roles": [
    {
      "id": "researcher",
      "activation": "internet_or_algorithm_research_needed",
      "owns": [
        "external_research",
        "algorithm_survey",
        "source_collection"
      ],
      "required_outputs": [
        "research_notes.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "research_notes"
        ],
        "notes": "Research findings are recorded in research notes, not direct repo edits."
      }
    },
    {
      "id": "research_reviewer",
      "activation": "internet_or_algorithm_research_needed",
      "owns": [
        "source_quality_review",
        "research_gap_review",
        "citation_review"
      ],
      "required_outputs": [
        "research_review.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "research_review"
        ],
        "notes": "The research reviewer checks source quality and whether the proposed research actually supports the plan."
      }
    },
    {
      "id": "experimenter",
      "activation": "benchmark_or_experiment_loop_needed",
      "owns": [
        "baseline_execution",
        "iterative_experiment_runs",
        "result_capture",
        "comparison_tracking"
      ],
      "required_outputs": [
        "experiment_log.md",
        "experiment_change_loop.md"
      ],
      "write_policy": {
        "mode": "runtime_outputs_plus_artifacts",
        "allowed_artifacts": [
          "experiment_log",
          "experiment_change_loop"
        ],
        "requires_worktree_scope": true,
        "notes": "The experimenter may write only run artifacts and runtime output directories explicitly listed in WORKTREE_SCOPE.md. It may not edit repository source files."
      }
    },
    {
      "id": "experiment_reviewer",
      "activation": "benchmark_or_experiment_loop_needed",
      "owns": [
        "critical_result_review",
        "comparison_validity_review",
        "overclaim_review"
      ],
      "required_outputs": [
        "experiment_review.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "experiment_review"
        ],
        "notes": "The experiment reviewer critiques fairness, comparison targets, interpretation, and whether the next code change is actually justified by the evidence."
      }
    },
    {
      "id": "scheduler",
      "activation": "explicit_execution_plan_required",
      "owns": [
        "execution_plan",
        "dependency_tracking",
        "delivery_checkpoints",
        "subagent_stage_plan",
        "validation_sequence_plan"
      ],
      "required_outputs": [
        "schedule.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "schedule"
        ],
        "notes": "Execution planning stays in the report bundle and must assign explicit stage owners, review separation, and subagent activation before detailed design begins."
      }
    },
    {
      "id": "schedule_reviewer",
      "activation": "explicit_execution_plan_required",
      "owns": [
        "execution_plan_review",
        "dependency_review",
        "delivery_risk_review",
        "reviewer_separation_review"
      ],
      "required_outputs": [
        "schedule_review.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "schedule_review"
        ],
        "notes": "The schedule reviewer checks execution order, reviewer separation, milestone realism, explicit stage activation, and sequencing risk. It must remain distinct from the design reviewer."
      }
    },
    {
      "id": "notation_definition_reviewer",
      "activation": "academic_or_symbol_dense_writing_review_needed",
      "owns": [
        "notation_review",
        "definition_order_review",
        "abbreviation_review",
        "symbol_consistency_review"
      ],
      "required_outputs": [
        "notation_definition_review.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "notation_definition_review"
        ],
        "notes": "The notation-definition reviewer checks whether symbols, abbreviations, technical terms, units, indices, and assumptions are defined before use and used consistently."
      }
    },
    {
      "id": "logic_gap_reviewer",
      "activation": "academic_or_claim_dense_writing_review_needed",
      "owns": [
        "logic_gap_review",
        "claim_to_evidence_review",
        "hidden_assumption_review",
        "result_interpretation_boundary_review"
      ],
      "required_outputs": [
        "logic_gap_review.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "logic_gap_review"
        ],
        "notes": "The logic-gap reviewer checks whether major claims are supported, whether inferential jumps are explicit, and whether results are kept separate from interpretation."
      }
    },
    {
      "id": "infra_steward",
      "activation": "ci_experiment_or_platform_work",
      "owns": [
        "infra_assessment",
        "experiment_runner_design",
        "automation_change_plan"
      ],
      "required_outputs": [
        "infra_notes.md",
        "environment_change_proposal.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "infra_notes",
          "environment_change_proposal"
        ],
        "notes": "Infra stewardship proposes and reviews infra changes, while the implementer applies repo edits."
      }
    },
    {
      "id": "infra_reviewer",
      "activation": "ci_experiment_or_platform_work",
      "owns": [
        "infra_safety_review",
        "operational_risk_review",
        "rollback_review"
      ],
      "required_outputs": [
        "infra_review.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "infra_review"
        ],
        "notes": "The infra reviewer checks rollout, safety, and maintenance cost before coding begins."
      }
    },
    {
      "id": "reproducibility_reviewer",
      "activation": "reproducibility_perspective_review_requested",
      "owns": [
        "provenance_review",
        "seed_and_command_review",
        "environment_capture_review",
        "rerunability_review"
      ],
      "required_outputs": [
        "reproducibility_review.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "reproducibility_review"
        ],
        "notes": "The reproducibility reviewer records rerunability findings only in the perspective review artifact."
      }
    },
    {
      "id": "scientific_computing_reviewer",
      "activation": "scientific_computing_perspective_review_requested",
      "owns": [
        "incremental_change_review",
        "testing_and_automation_review",
        "prototype_discipline_review"
      ],
      "required_outputs": [
        "scientific_computing_review.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "scientific_computing_review"
        ],
        "notes": "The scientific computing reviewer records workflow and engineering findings only in the perspective review artifact."
      }
    },
    {
      "id": "benchmark_reviewer",
      "activation": "benchmark_perspective_review_requested",
      "owns": [
        "fairness_review",
        "confounder_review",
        "case_mix_review",
        "benchmark_antipattern_review"
      ],
      "required_outputs": [
        "benchmark_review.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "benchmark_review"
        ],
        "notes": "The benchmark reviewer records fairness and confounder findings only in the perspective review artifact."
      }
    },
    {
      "id": "artifact_reviewer",
      "activation": "artifact_perspective_review_requested",
      "owns": [
        "artifact_completeness_review",
        "raw_result_review",
        "environment_bundle_review",
        "rerun_package_review"
      ],
      "required_outputs": [
        "artifact_review.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "artifact_review"
        ],
        "notes": "The artifact reviewer records bundle-readiness findings only in the perspective review artifact."
      }
    },
    {
      "id": "fair_data_reviewer",
      "activation": "fair_data_perspective_review_requested",
      "owns": [
        "metadata_review",
        "naming_review",
        "result_path_review",
        "reuse_review"
      ],
      "required_outputs": [
        "fair_data_review.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "fair_data_review"
        ],
        "notes": "The fair data reviewer records metadata and reuse findings only in the perspective review artifact."
      }
    },
    {
      "id": "ml_science_reviewer",
      "activation": "ml_science_perspective_review_requested",
      "owns": [
        "assumption_review",
        "limitation_review",
        "uncertainty_review",
        "reader_facing_reporting_review"
      ],
      "required_outputs": [
        "ml_science_review.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "ml_science_review"
        ],
        "notes": "The ML-science reviewer records reporting and overclaim findings only in the perspective review artifact."
      }
    },
    {
      "id": "project_reviewer",
      "activation": "repo_wide_or_comprehensive_review_needed",
      "owns": [
        "repo_inventory_review",
        "integration_risk_review",
        "settings_vs_docs_review",
        "stale_surface_review"
      ],
      "required_outputs": [
        "project_review.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "project_review"
        ],
        "notes": "The project reviewer records repo-wide inventory and integration findings only in the project review artifact."
      }
    },
    {
      "id": "docs_workflow_steward",
      "activation": "workflow_or_adapter_docs_change_needed",
      "owns": [
        "workflow_canon_review",
        "adapter_surface_review",
        "docs_duplication_review",
        "runtime_entrypoint_cleanup_plan"
      ],
      "required_outputs": [
        "docs_workflow_review.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "docs_workflow_review"
        ],
        "notes": "The docs-workflow steward records canon and adapter findings only in the docs-workflow review artifact."
      }
    },
    {
      "id": "python_reviewer",
      "activation": "python_change_review_needed",
      "owns": [
        "pyright_review",
        "pytest_review",
        "ruff_review",
        "python_behavior_review"
      ],
      "required_outputs": [
        "python_review.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "python_review"
        ],
        "notes": "The Python reviewer records type, test, and lint findings only in the python review artifact."
      }
    },
    {
      "id": "report_reviewer",
      "activation": "report_or_claim_heavy_output_needed",
      "owns": [
        "report_structure_review",
        "evidence_traceability_review",
        "claim_strength_review",
        "reader_facing_report_review"
      ],
      "required_outputs": [
        "report_review.md"
      ],
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "report_review"
        ],
        "notes": "The report reviewer records report-structure and evidence-traceability findings only in the report review artifact."
      }
    },
    {
      "id": "critical_guardian",
      "tier": "governance",
      "activation": "always_on",
      "always_evaluates": [
        "pull_requests",
        "skill_executions",
        "releases",
        "scheduled_reviews"
      ],
      "owns": [
        "critical_risk_assessment",
        "security_threat_detection",
        "architecture_validation",
        "testing_completeness_check",
        "dependency_conflict_analysis",
        "implementation_gap_detection"
      ],
      "required_outputs": [
        "critical_review.md"
      ],
      "authority": {
        "can_block_merge": true,
        "can_request_changes": true,
        "can_downvote_health_score": true,
        "escalation_capable": true
      },
      "write_policy": {
        "mode": "artifacts_only",
        "allowed_artifacts": [
          "critical_review"
        ],
        "notes": "The critical guardian provides always-on critical assessment of risks, security threats, and implementation completeness. Can block merge on critical issues only. Provides alternative suggestions and gap analysis."
      }
    }
  ],
  "handoffs": [
    {
      "from": "manager",
      "to": "manager_reviewer",
      "gate": "intent, acceptance criteria, and scope package is written"
    },
    {
      "from": "manager_reviewer",
      "to": "manager",
      "gate": "management review feedback is resolved or escalated"
    },
    {
      "from": "manager",
      "to": "researcher",
      "gate": "research is required and intake package is approved"
    },
    {
      "from": "manager",
      "to": "scheduler",
      "gate": "requirements package is approved and execution planning can begin"
    },
    {
      "from": "manager",
      "to": "infra_steward",
      "gate": "task touches CI, experiments, docker, or platform automation and intake package is approved"
    },
    {
      "from": "manager",
      "to": "project_reviewer",
      "gate": "repo-wide or comprehensive integration review is required and intake package is approved"
    },
    {
      "from": "project_reviewer",
      "to": "manager",
      "gate": "project review findings are recorded or escalated"
    },
    {
      "from": "manager",
