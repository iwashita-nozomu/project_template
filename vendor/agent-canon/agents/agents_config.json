  "activation_rules": [
    {
      "role": "researcher",
      "when": "algorithm choice, internet lookup, or external verification is needed"
    },
    {
      "role": "research_reviewer",
      "when": "researcher is active"
    },
    {
      "role": "experimenter",
      "when": "task needs baseline measurement, repeated experiment runs, or empirical validation loops"
    },
    {
      "role": "experiment_reviewer",
      "when": "experimenter is active"
    },
    {
      "role": "scheduler",
      "when": "repo-changing task needs explicit execution planning before detailed design"
    },
    {
      "role": "schedule_reviewer",
      "when": "scheduler is active"
    },
    {
      "role": "notation_definition_reviewer",
      "when": "academic-writing is active or the document is symbol-dense, abbreviation-dense, or notation-heavy"
    },
    {
      "role": "logic_gap_reviewer",
      "when": "academic-writing is active or the document is claim-dense, citation-heavy, or inferentially complex"
    },
    {
      "role": "infra_steward",
      "when": "task touches CI, Docker, experiment runners, or platform automation"
    },
    {
      "role": "infra_reviewer",
      "when": "infra_steward is active"
    },
    {
      "role": "project_reviewer",
      "when": "task is comprehensive, repo-wide, workflow-heavy, or has integration risk across code, docs, tools, and runtime"
    },
    {
      "role": "docs_workflow_steward",
      "when": "task touches workflow docs, agent canon, adapters, entrypoints, or large reader-facing documentation"
    },
    {
      "role": "python_reviewer",
      "when": "Python source, tests, or Python-facing behavior changes"
    },
    {
      "role": "test_designer",
      "when": "task changes code, parsing, edge-case handling, tests, or public behavior and needs adversarial static test design before implementation"
    },
    {
      "role": "report_reviewer",
      "when": "task produces an experiment report, claim-heavy note, or other evidence-facing narrative output"
    },
    {
      "role": "reproducibility_reviewer",
      "when": "research perspective review pack is requested for provenance, rerunability, or environment evidence"
    },
    {
      "role": "scientific_computing_reviewer",
      "when": "research perspective review pack is requested for workflow, automation, or prototype discipline"
    },
    {
      "role": "benchmark_reviewer",
      "when": "research perspective review pack is requested for benchmark fairness, confounders, or case-mix review"
    },
    {
      "role": "artifact_reviewer",
      "when": "research perspective review pack is requested for artifact completeness or rerun package review"
    },
    {
      "role": "fair_data_reviewer",
      "when": "research perspective review pack is requested for metadata, naming, or reuse review"
    },
    {
      "role": "ml_science_reviewer",
      "when": "research perspective review pack is requested for assumptions, limitations, uncertainty, or reader-facing reporting"
    },
    {
      "role": "critical_guardian",
      "when": "pull request created, skill execution completed, release initiated, or scheduled daily review at 02:00 UTC"
    }
  ],
  "quality_gates": [
    "make agent-checks",
    "scripts/ci/pre_review.sh",
    "make ci"
  ],
